# =================================================================
# MinusPod Environment Configuration
# =================================================================
# Copy this file to .env and fill in your values.
# Only uncomment the variables you need for your chosen provider.

# =================================================================
# LLM Provider (choose one)
# =================================================================

# Option 1: Anthropic (default) -- direct Claude API access
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Option 2: OpenRouter -- access 200+ models via one API key
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENAI_MODEL=anthropic/claude-sonnet-4-5  # Any OpenRouter model ID

# Option 3: OpenAI-compatible (Claude Code wrapper, custom endpoints)
# LLM_PROVIDER=openai-compatible
# OPENAI_BASE_URL=http://claude-wrapper:8000/v1
# OPENAI_API_KEY=not-needed
# OPENAI_MODEL=claude-sonnet-4-5-20250929

# Option 4: Ollama (local inference, no API costs)
# LLM_PROVIDER=ollama
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1
# OPENAI_MODEL=qwen3:14b

# =================================================================
# Whisper Transcription (choose one)
# =================================================================

# Option 1: Local GPU (default) -- requires NVIDIA GPU
WHISPER_MODEL=small
WHISPER_DEVICE=cuda

# Option 2: OpenAI-compatible Whisper API (Groq, OpenAI, whisper.cpp)
# WHISPER_BACKEND=openai-api
# WHISPER_API_BASE_URL=https://api.groq.com/openai/v1
# WHISPER_API_KEY=your-whisper-api-key
# WHISPER_API_MODEL=whisper-large-v3-turbo
# WHISPER_DEVICE=cpu

# =================================================================
# Server Configuration
# =================================================================
BASE_URL=http://localhost:8000

# Retention period in minutes (legacy, prefer Settings UI)
# RETENTION_PERIOD=1440

# Cloudflare tunnel (optional, for remote access)
# TUNNEL_TOKEN=your-tunnel-token
